{
	"name": "plugin-rotating-tagline",
	"version": "0.1.1",
	"description": "EmDash plugin that rotates the site tagline from a configurable list",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./sandbox": "./dist/sandbox-entry.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup src/index.ts src/sandbox-entry.ts --format esm --dts",
		"prepublishOnly": "npm run build"
	},
	"keywords": ["emdash", "cms", "plugin", "tagline"],
	"license": "MIT",
	"peerDependencies": {
		"emdash": ">=0.1.0"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.0.0"
	}
}
